# Google Gemini — modelo principal del agente (gemini-2.5-flash, barato + rápido)
# Obtén la key en https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...

# Composio Gmail MCP — opcional, fallback a mock si no está
# Obtenla en https://app.composio.dev → tu app → MCP tab
COMPOSIO_MCP_URL=https://mcp.composio.dev/...

# Opcional: deshabilita telemetría de Next.js
NEXT_TELEMETRY_DISABLED=1
